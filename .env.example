# Required: shared secret used by frontends to authenticate to the API.
# Generate with:  openssl rand -hex 32
APPFOLIO_API_KEY=replace-with-a-long-random-secret

# Caddy reverse proxy:
#   - "localhost"  → plain HTTP on :80, no TLS (local dev)
#   - any real FQDN (e.g. api.example.com) → automatic HTTPS via Let's Encrypt
CADDY_DOMAIN=localhost

# Email used for Let's Encrypt registration when CADDY_DOMAIN is a real FQDN.
# Ignored when CADDY_DOMAIN=localhost.
CADDY_ACME_EMAIL=admin@example.com
